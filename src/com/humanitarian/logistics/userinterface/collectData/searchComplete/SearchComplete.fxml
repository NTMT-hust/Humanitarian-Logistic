<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane stylesheets="@style.css" maxHeight="-Infinity" maxWidth="-Infinity" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" 
fx:controller="com.humanitarian.logistics.userinterface.collectData.searchComplete.CompleteController">
   <children>
      <!-- 
         Using 'init-card' class for consistent white card look.
         Removed manual prefHeight/Width constraints to let padding/content dictate size, 
         but you can add them back if you want a fixed size.
      -->
      <VBox alignment="CENTER" styleClass="init-card">
         <children>
            
            <!-- Success Title -->
            <Label alignment="CENTER" contentDisplay="CENTER" styleClass="success-header" text="Search Completed!">
            </Label>
            
            <!-- Details / Status -->
            <Label fx:id="statusLabel" alignment="CENTER" styleClass="result-details-label" text="Data collection finished successfully.">
            </Label>
            
            <!-- Action Button -->
            <Button fx:id="backButton" mnemonicParsing="false" onAction="#returnToMenu" styleClass="button-primary" text="Back to Problem Selection" />
         
         </children>
      </VBox>
   </children>
</StackPane>