<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="768.0" prefWidth="1080.0" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.humanitarian.logistics.userinterface.textExtraction.startExtraction.StartExtractionController">
   <top>
      <VBox BorderPane.alignment="CENTER">
         <children>
            
            <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="1080.0" spacing="15.0">
               <children>
                  <!-- Applied header-label -->
                  <Label prefHeight="35.0" prefWidth="250.0" styleClass="header-label" text="Text Extraction">
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
                  
                  <!-- Applied search-field (and standard text-field style) -->
                  <TextField fx:id="textField" maxHeight="1.7976931348623157E308" prefHeight="40.0" prefWidth="600.0" promptText="Enter keywords to extract..." styleClass="search-field" HBox.hgrow="ALWAYS">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </TextField>
                  
                  <!-- Applied button-primary -->
                  <Button fx:id="button" maxHeight="1.7976931348623157E308" mnemonicParsing="false" onAction="#startExtract" prefHeight="40.0" prefWidth="120.0" styleClass="button-primary" text="Submit" textAlignment="RIGHT">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Button>
               </children>
               <VBox.margin>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="5.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </top>
   <center>
      <StackPane fx:id="contentArea" prefHeight="150.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <!-- Applied 'card' class for white background and shadow -->
            <TabPane fx:id="mainTabPane" prefHeight="684.0" prefWidth="1020.0" styleClass="card" tabClosingPolicy="UNAVAILABLE">
              <tabs>
                <Tab fx:id="youtubeTab" text="YouTube">
                  <content>
                    <AnchorPane fx:id="youtubeChartPane" minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <BarChart layoutX="14.0" layoutY="14.0" prefHeight="550.0" prefWidth="1000.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                                <xAxis>
                                  <CategoryAxis side="BOTTOM" />
                                </xAxis>
                                <yAxis>
                                  <NumberAxis side="LEFT" />
                                </yAxis>
                              </BarChart>
                           </children></AnchorPane>
                  </content>
                </Tab>
                <Tab fx:id="googleCSETab" text="GoogleCSE">
                  <content>
                    <AnchorPane fx:id="googleChartPane" minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <BarChart layoutX="14.0" layoutY="14.0" prefHeight="550.0" prefWidth="1000.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                                <xAxis>
                                  <CategoryAxis side="BOTTOM" />
                                </xAxis>
                                <yAxis>
                                  <NumberAxis side="LEFT" />
                                </yAxis>
                              </BarChart>
                           </children>
                        </AnchorPane>
                  </content>
                </Tab>
                  <Tab fx:id="newsAPITab" text="NewsAPI">
                    <content>
                      <AnchorPane fx:id="newsChartPane" minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <BarChart layoutX="14.0" layoutY="14.0" prefHeight="550.0" prefWidth="1000.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                                <xAxis>
                                  <CategoryAxis side="BOTTOM" />
                                </xAxis>
                                <yAxis>
                                  <NumberAxis side="LEFT" />
                                </yAxis>
                              </BarChart>
                           </children>
                        </AnchorPane>
                    </content>
                  </Tab>
              </tabs>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" />
               </padding>
            </TabPane>
         </children>
      </StackPane>
   </center>
   <bottom>
      <!-- Top Navigation Bar -->
      <ButtonBar BorderPane.alignment="CENTER">
        <buttons>
            <!-- Applied button-secondary -->
            <Button fx:id="backBtn" mnemonicParsing="false" onAction="#returnBtnPressed" styleClass="button-secondary" text="Back" />
        </buttons>
         <padding>
            <Insets bottom="10.0" right="10.0" top="10.0" />
         </padding>
      </ButtonBar>
   </bottom>
</BorderPane>
