<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.humanitarian.logistics.userinterface.collectData.cancelling.CancellingController">
   <children>
      <!-- Reusing 'init-card' for the white box, shadow, and padding -->
      <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" styleClass="init-card">
      
          <!-- Used 'status-label-danger' for Red text, or use 'status-label' for standard Dark Blue -->
          <Label styleClass="status-label-danger" text="Cancelling...">
              <!-- Font size is now handled by CSS, but you can keep this override if needed -->
          </Label>
      
          <!-- Progress bar automatically inherits global style -->
          <ProgressBar fx:id="progressBar" prefWidth="250.0" progress="0.0" />
      
      </VBox>
   </children>
</StackPane>